# NodeSeek 签到脚本配置

# NodeSeek Cookie（必填）
# 从浏览器 F12 → Network → 复制完整 Cookie
# 需包含: session, cf_clearance, smac, fog, hmti_
NODESEEK_COOKIE=

# 代理地址（可选）
NODESEEK_PROXY_URL=http://192.168.3.4:7890

# 签到模式
# true=随机鸡腿（推荐），false=固定5鸡腿
NODESEEK_SIGN_RANDOM=true

# 延迟配置（三选一，优先级：固定延迟 > 随机延迟 > 不延迟）

# 方式1: 固定延迟（秒）
NODESEEK_FIXED_DELAY=0

# 方式2: 随机延迟范围（秒）
NODESEEK_RANDOM_DELAY_MIN=0
NODESEEK_RANDOM_DELAY_MAX=0

# 签到站点域名（可选）
SITE_DOMAIN=www.nodeseek.com
